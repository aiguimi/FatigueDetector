{
  "compilerOptions": {
    "target": "esnext", "module": "commonjs", "lib": ["esnext"],
    "allowJs": true, "jsx": "react-native", "noEmit": true,
    "strict": true, "moduleResolution": "node",
    "resolveJsonModule": true, "esModuleInterop": true, "skipLibCheck": true,
    "baseUrl": ".", "paths": { "@/*": ["src/*"] }
  },
  "include": ["App.tsx", "index.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "android", "ios", "DriverFatigueDetector_v4"]
}